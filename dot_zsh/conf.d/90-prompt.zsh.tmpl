{{- $isDarwin := eq .chezmoi.os "darwin" -}}
{{- $isLinux := eq .chezmoi.os "linux" -}}

# ── Prompt & history tools (must be last) ────────────────────────────────────

# Syntax highlighting theme (must come before the plugin itself on macOS)
source "$HOME/.zsh/catppuccin_mocha-zsh-syntax-highlighting.zsh"

# Zsh plugins — on macOS installed via Homebrew, on NixOS enabled system-wide
{{- if $isDarwin }}
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
{{- end }}

# Disable built-in zsh history (atuin replaces it entirely)
unsetopt APPEND_HISTORY
unsetopt INC_APPEND_HISTORY
unsetopt SHARE_HISTORY
HISTSIZE=1000
SAVEHIST=0
HISTFILE=/dev/null

# zoxide — smarter cd (replaces z/autojump), must be before starship
eval "$(zoxide init zsh)"

# Starship prompt
eval "$(starship init zsh)"

# Atuin — shell history (must be last)
eval "$(atuin init zsh)"
