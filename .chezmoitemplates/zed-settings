    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      // "enable_thinking": false,
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6"
    },
    "model_parameters": []
  },
  "wsl_connections": [
    {
      "distro_name": "NixOS",
      "user": null,
      "projects": [
        {
          "paths": ["/home/jeomhps/freebsd"]
        }
      ]
    }
  ],
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Catppuccin Mocha"
  },
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
    "git-firefly": true,
    "html": true,
    "log": true,
    "toml": true,
    "typst": true
  },
  "file_types": {
    "JSONC": ["*.json.tmpl", "**/zed-settings", "**/zed-keymap", "**/zed-tasks"]
