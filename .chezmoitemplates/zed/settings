// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)

{{- $base := fromYaml (include ".chezmoitemplates/zed/base.yaml") }}
{{- $theme := fromYaml (include ".chezmoitemplates/zed/theme.yaml") }}
{{- $agent := fromYaml (include ".chezmoitemplates/zed/agent.yaml") }}
{{- $extensions := fromYaml (include ".chezmoitemplates/zed/extensions.yaml") }}
{{- $layout := fromYaml (include ".chezmoitemplates/zed/layout.yaml") }}

{{- $merged := merge $base $theme $agent $extensions $layout }}
{{- if index . "zed_copilot_uri" }}
  {{- $workContent := include ".chezmoitemplates/zed/work.yaml" | replace "{{ .zed_copilot_uri }}" .zed_copilot_uri }}
  {{- $work := fromYaml $workContent }}
  {{- $merged = merge $merged $work }}
{{- end }}

{{ toPrettyJson $merged }}
